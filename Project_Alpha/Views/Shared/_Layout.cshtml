<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Konditerem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container-xl">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Konditerem</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="mainNav" class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link" href="#users">Felhasználók</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#hours">Nyitvatartás</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#capacity">Kapacitás</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#bookings">Foglalások</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-xl">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-shell">
        <div class="container-xl footer-content">
            <span>&copy; 2026 Konditerem Management System</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        window.addEventListener('load', function () {
            var pos = sessionStorage.getItem('scrollPos');
            if (pos) {
                window.scrollTo(0, parseInt(pos));
                sessionStorage.removeItem('scrollPos');
            }

            setTimeout(function () {
                document.querySelectorAll('.alert').forEach(function (el) {
                    el.style.transition = 'opacity 0.5s';
                    el.style.opacity = '0';
                    setTimeout(function () { el.remove(); }, 500);
                });
            }, 3000);
        });

        document.querySelectorAll('form').forEach(function (form) {
            form.addEventListener('submit', function () {
                sessionStorage.setItem('scrollPos', window.scrollY);
            });
        });
    </script>
</body>
</html>
